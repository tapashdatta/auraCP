# auraCP-managed static-HTML site — nginx serves the docroot directly.
# No backend, no FPM, no upstream.

{{bot_map}}

server {
    listen 80;
    listen [::]:80;
    {{ssl_listen}}

    {{server_name}}
    {{root}}
    index index.html;

    {{ssl_certificate}}
    {{ssl_certificate_key}}
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    location ^~ /.well-known/acme-challenge/ {
        root /var/lib/auracp/acme/;
        default_type "text/plain";
        try_files $uri =404;
    }

    # v0.2.57: optional :80 → :443 redirect (Settings → General toggle).
    {{force_https}}

    {{nginx_access_log}}
    {{nginx_error_log}}

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options nosniff always;
    server_tokens off;
    client_max_body_size 64m;

    {{bot_check}}
    {{basic_auth}}

    location ~ /\.(?!well-known) { deny all; }

    {{settings}}

    location / {
        try_files $uri $uri/ =404;
    }

    location ~* \.(css|js|jpg|jpeg|gif|png|ico|svg|woff|woff2|ttf|otf|webp|webm|mp4|map)$ {
        expires max;
        access_log off;
        add_header Cache-Control "public, immutable";
    }
}
