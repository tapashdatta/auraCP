# auraCP-managed PHP site — do not edit by hand; rewritten on every
# panel save. Operator-customizable nginx fragments go in the Vhost-tab
# textarea (rendered at the {{settings}} placeholder below).
#
# Single server block: HTTP + HTTPS on the same vhost via `listen 80;`
# and `listen 443 ssl;`. nginx auto-routes by scheme; HTTP redirects to
# HTTPS once a cert is issued (the redirect lives in {{settings}} or is
# left to the operator — sites work plaintext on :80 while the first
# ACME issuance is in flight).

{{bot_map}}

server {
    {{http_listen}}
    {{ssl_listen}}

    {{server_name}}
    {{root}}
    index index.php index.html;

    {{ssl_certificate}}
    {{ssl_certificate_key}}
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # ACME HTTP-01 challenge — always plaintext on :80, even after the
    # cert lands. Renewals need it.
    location ^~ /.well-known/acme-challenge/ {
        root /var/lib/auracp/acme/;
        default_type "text/plain";
        try_files $uri =404;
    }

    # v0.2.57: optional :80 → :443 redirect, gated on a cert being
    # installed (toggle lives in Settings → General). The block above
    # short-circuits this for /.well-known/acme-challenge/ paths.
    {{force_https}}

    {{nginx_access_log}}
    {{nginx_error_log}}

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    server_tokens off;
    client_max_body_size 64m;

    {{bot_check}}
    {{basic_auth}}
    {{cache_skip}}

    # Deny dotfiles except the ACME challenge.
    location ~ /\.(?!well-known) { deny all; }

    {{settings}}

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        {{php_fpm_socket}}
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        fastcgi_param HTTPS $https if_not_empty;
        fastcgi_read_timeout 120s;
        {{fastcgi_cache}}
    }
}
