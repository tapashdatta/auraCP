# auraCP-managed reverse-proxy site — every request goes to the
# operator-supplied upstream URL.  No docroot beyond the ACME path.

{{bot_map}}

server {
    listen 80;
    listen [::]:80;
    {{ssl_listen}}

    {{server_name}}

    {{ssl_certificate}}
    {{ssl_certificate_key}}
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    location ^~ /.well-known/acme-challenge/ {
        root /var/lib/auracp/acme/;
        default_type "text/plain";
        try_files $uri =404;
    }

    # v0.2.57: optional :80 → :443 redirect (Settings → General toggle).
    {{force_https}}

    {{nginx_access_log}}
    {{nginx_error_log}}

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options nosniff always;
    server_tokens off;
    client_max_body_size 64m;

    {{bot_check}}
    {{basic_auth}}
    {{cache_skip}}

    location ~ /\.(?!well-known) { deny all; }

    {{settings}}

    location / {
        {{reverse_proxy_url}}
        {{proxy_cache}}
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_ssl_server_name on;
        proxy_read_timeout 90s;
    }
}
