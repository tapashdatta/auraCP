# Go build output
/bin/
/dist/

# Node deps and Vite output (the embedded copy in internal/webui/dist IS committed,
# so the Go binary builds without npm; web/dist is just the intermediate)
web/node_modules/
web/dist/

# Aura DB SPA build artifacts (PR #11 INT-6). The embedded copy in
# internal/dbadmin/webui/dist IS committed (the .gitkeep there is the
# only file that should be visible after a clean), and the intermediate
# web-aura-db/dist is rebuilt by the Makefile.
web-aura-db/node_modules/
web-aura-db/dist/

# Local runtime data & secrets (never commit these)
*.db
*.db-wal
*.db-shm
secret.key
auracp.db*

# OS / editor cruft
.DS_Store
*.swp

# Claude Code agent state — worktrees, transcripts, scratch artifacts.
# Lives in the operator's checkout, never committed.
.claude/

# Standalone HTML mock-ups produced during design exploration; not part
# of the panel source.
auraDBPrototype.html
aura-db
auracpd
graphify-out
